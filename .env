# Kafka
KAFKA_BROKER=localhost:9092

KAFKA_TOPIC=earthquakes,usgs_by_region,usgs_last_day,usgs_significant_week
FETCH_INTERVAL=10

# Faust
FAUST_APP_NAME=
FAUST_BROKER=

# Flask

# USGS API
USGS_API_FLUX_GEOJSON=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
USGS_LAST_DAY=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson
USGS_SIGNIFICANT_WEEK=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/significant_week.geojson
USGS_M4_5_DAY=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/4.5_day.geojson
USGS_API_ALL_MONTH=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_month.geojson
USGS_API_QUERY=https://earthquake.usgs.gov/fdsnws/event/1/query

# Création des topics

CMD = .\bin\windows\kafka-topics.bat --create --topic earthquakes \ --bootstrap-server localhost:9092 \ --partitions 1 --replication-factor 1
CMD = .\bin\windows\kafka-topics.bat --create --topic usgs_last_day \ --bootstrap-server localhost:9092 \ --partitions 1 --replication-factor 1
CMD = .\bin\windows\kafka-topics.bat --create --topic usgs_significant_week \ --bootstrap-server localhost:9092 \ --partitions 1 --replication-factor 1
CMD = .\bin\windows\kafka-topics.bat --create --topic usgs_by_region \ --bootstrap-server localhost:9092 \ --partitions 8 --replication-factor 1

CMD_DELETE= .\bin\windows\kafka-topics.bat --bootstrap-server localhost:9092 --delete --topic earthquake-stream-stats-changelog